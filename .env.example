# ---------------------------------------------------------------------------
# MobZ — LOCAL DEVELOPMENT ONLY.
# The evaluation harness injects the real values at runtime. Never bake this
# file into the Docker image (it is excluded via .dockerignore).
# ---------------------------------------------------------------------------

# --- Injected by the harness (required) ---
FIREWORKS_API_KEY=your-local-dev-key
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
ALLOWED_MODELS=accounts/fireworks/models/model-a,accounts/fireworks/models/model-b

# --- I/O paths (defaults match the harness contract) ---
MOBZ_INPUT_PATH=/input/tasks.json
MOBZ_OUTPUT_PATH=/output/results.json

# --- Placeholder integration points ---
# Point these at YOUR local model and YOUR non-relational profiles DB.
# The gold DB (mobz_model_profiles.json) at the repo root is auto-detected if
# MOBZ_PROFILES_DB_URI is empty.
MOBZ_COGNITIVE_MODEL_PATH=
MOBZ_PROFILES_DB_URI=
# Local Gemma prompt-compressor model dir (Module 2). Empty -> heuristic fallback.
MOBZ_COMPRESSOR_MODEL_PATH=
# Compression on/off (default on). Set "off" to disable Module 2 entirely.
MOBZ_COMPRESSION=on
# Base encoder used to rebuild the ModernBERT multi-head analyzer (only needed
# if the model dir lacks config.json / tokenizer files).
MOBZ_ENCODER_NAME=answerdotai/ModernBERT-base

# --- Pipeline tuning (optional) ---
MOBZ_MAX_RUNTIME_SECONDS=570
MOBZ_CONCURRENCY=8
MOBZ_REQUEST_TIMEOUT=60
MOBZ_MAX_RETRIES=2
MOBZ_QUALITY_THRESHOLD=0.70
MOBZ_OUTPUT_TOKEN_MARGIN=1.5
MOBZ_MIN_OUTPUT_TOKENS=256
MOBZ_MAX_OUTPUT_TOKENS=4096
# System instruction steering models to answer concisely (set empty to disable).
# MOBZ_SYSTEM_PROMPT=
MOBZ_LOG_LEVEL=INFO
